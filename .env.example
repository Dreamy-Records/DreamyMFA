PORT=5173
HOST=127.0.0.1
BASE_URL=http://127.0.0.1:5173

# Production example:
# ENV_FILE itself is set outside this file, before starting node.
# Linux:   ENV_FILE=/home/app/secure/authenticator.env node serve.js
# Windows: $env:ENV_FILE = "D:\secure\authenticator\.env"

# Discord Developer Portal > OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:5173/auth/discord/callback

# Require membership in this Discord server.
DISCORD_REQUIRED_GUILD_ID=

# Users allowed to open the page. Leave empty to allow any member of the required guild.
DISCORD_ALLOWED_USER_IDS=

# Users allowed to add/delete TOTP seeds. Comma-separated Discord user IDs.
# If empty, DISCORD_ALLOWED_USER_IDS users can add/delete.
DISCORD_SECRET_MANAGER_USER_IDS=

# Generate a long random string for production.
SESSION_SECRET=change-me-before-production

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_CONNECTION_LIMIT=10

# Used to encrypt TOTP secrets before writing them to MySQL.
# Recommended: 64 hex chars, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
VAULT_ENCRYPTION_KEY=
